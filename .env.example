# Copiá este archivo a ".env" para desarrollo local (nunca subas el ".env" real).
# En producción, estas mismas variables se cargan en Vercel: Project Settings > Environment Variables.

# Panel de Supabase > Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Usuario del panel admin
ADMIN_USER=admin

# Hash de la contraseña del panel admin. Generarlo con:
#   node scripts/hash-password.js "tuContraseñaSegura"
# y pegar acá el resultado (NO la contraseña en texto plano).
ADMIN_PASSWORD_HASH=

# Cadena aleatoria y larga para firmar la sesión del panel. Generarla con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
